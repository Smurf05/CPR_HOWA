<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HOWA.Admin.ViewModels"
             xmlns:helpers="clr-namespace:HOWA.Admin.Helpers"
             x:Class="HOWA.Admin.Controls.ChatbotWidget"
             BackgroundColor="#1E293B">

    <ContentView.Resources>
        <ResourceDictionary>
            <helpers:UserMarginConverter x:Key="UserMarginConverter" />
            <helpers:UserColorConverter x:Key="UserColorConverter" />
        </ResourceDictionary>
    </ContentView.Resources>

    <Grid RowDefinitions="Auto, *, Auto" Padding="15" RowSpacing="10" HeightRequest="450" WidthRequest="320">
        
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="0,0,0,10">
            <Label Grid.Column="0" Text="HOWA AI Chatbot" FontAttributes="Bold" TextColor="#FFFFFF" FontSize="14" VerticalOptions="Center" />
            <BoxView Grid.Column="1" WidthRequest="8" HeightRequest="8" CornerRadius="4" Color="#10B981" VerticalOptions="Center" />
        </Grid>

        <!-- Message List -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Messages}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:ChatMessage">
                    <Grid Padding="5">
                        <Border StrokeShape="RoundRectangle 8" Padding="10" Margin="{Binding IsUser, Converter={StaticResource UserMarginConverter}}"
                                BackgroundColor="{Binding IsUser, Converter={StaticResource UserColorConverter}}">
                            <Label Text="{Binding Text}" TextColor="#FFFFFF" FontSize="12" MaxLines="10" />
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Text input and Send button -->
        <Grid Grid.Row="2" ColumnDefinitions="*, Auto" ColumnSpacing="8" Padding="0,10,0,0">
            <Entry Grid.Column="0" Text="{Binding UserText}" Placeholder="Ask about attendance..." PlaceholderColor="#64748B" TextColor="#FFFFFF" BackgroundColor="#0F172A" HeightRequest="40" FontSize="12" />
            <Button Grid.Column="1" Text="Send" Command="{Binding SendCommand}" BackgroundColor="#3B82F6" TextColor="#FFFFFF" FontAttributes="Bold" HeightRequest="40" CornerRadius="6" FontSize="12" />
        </Grid>
    </Grid>
</ContentView>
