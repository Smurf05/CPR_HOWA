<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HOWA.Admin.ViewModels"
             xmlns:dto="clr-namespace:HOWA.Domain.DTOs;assembly=HOWA.Domain"
             xmlns:helpers="clr-namespace:HOWA.Admin.Helpers"
             x:Class="HOWA.Admin.Views.AttendancePage"
             Title="Attendance Logs Sheet"
             BackgroundColor="#0F172A">

    <ContentPage.Resources>
        <ResourceDictionary>
            <helpers:StatusToColorConverter x:Key="StatusToColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *" Padding="30" RowSpacing="20">
        
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
            <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                <BoxView Color="#10B981" WidthRequest="6" HeightRequest="30" CornerRadius="3" />
                <Label Text="Live Attendance Sheet" FontSize="24" FontAttributes="Bold" TextColor="#FFFFFF" />
            </HorizontalStackLayout>
            <Button Grid.Column="1" Text="Refresh Logs" Command="{Binding LoadLogsCommand}" BackgroundColor="#1E293B" TextColor="#E2E8F0" HeightRequest="40" CornerRadius="8" />
        </Grid>

        <!-- Attendance List -->
        <Border Grid.Row="1" StrokeShape="RoundRectangle 12" Stroke="#1E293B" BackgroundColor="#1E293B" Padding="10">
            <Grid RowDefinitions="Auto, *">
                
                <!-- Table headers -->
                <Grid Grid.Row="0" ColumnDefinitions="80, *, 120, 150, 120, 120" Padding="15" BackgroundColor="#111827">
                    <Label Grid.Column="0" Text="Log ID" FontAttributes="Bold" TextColor="#94A3B8" />
                    <Label Grid.Column="1" Text="Name" FontAttributes="Bold" TextColor="#94A3B8" />
                    <Label Grid.Column="2" Text="Role" FontAttributes="Bold" TextColor="#94A3B8" />
                    <Label Grid.Column="3" Text="Event Checked" FontAttributes="Bold" TextColor="#94A3B8" />
                    <Label Grid.Column="4" Text="Scan Method" FontAttributes="Bold" TextColor="#94A3B8" />
                    <Label Grid.Column="5" Text="Status" FontAttributes="Bold" TextColor="#94A3B8" />
                </Grid>

                <!-- Table content -->
                <CollectionView Grid.Row="1" ItemsSource="{Binding Logs}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dto:AttendanceReportDto">
                            <Grid ColumnDefinitions="80, *, 120, 150, 120, 120" Padding="15">
                                <Label Grid.Column="0" Text="{Binding LogId}" TextColor="#E2E8F0" />
                                <Label Grid.Column="1" Text="{Binding FullName}" TextColor="#FFFFFF" FontAttributes="Bold" />
                                <Label Grid.Column="2" Text="{Binding UserRole}" TextColor="#94A3B8" />
                                <Label Grid.Column="3" Text="{Binding EventName}" TextColor="#E2E8F0" />
                                <Label Grid.Column="4" Text="{Binding AttendanceMethod}" TextColor="#E2E8F0" />
                                <Label Grid.Column="5" Text="{Binding AttendanceStatus}" FontAttributes="Bold"
                                       TextColor="{Binding AttendanceStatus, Converter={StaticResource StatusToColorConverter}}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
