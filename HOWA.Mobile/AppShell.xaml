<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HOWA.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:HOWA.Mobile.Views"
    Title="HOWA.Mobile"
    FlyoutBehavior="Disabled">

    <!-- Startup page - Login -->
    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="LoginPage" />

    <!-- Register Screen -->
    <ShellContent
        Title="Register"
        ContentTemplate="{DataTemplate views:RegisterPage}"
        Route="RegisterPage" />

    <!-- Main Tab Layout once authenticated -->
    <TabBar>
        <Tab Title="QR Gate Pass" Icon="dotnet_bot.png">
            <ShellContent
                ContentTemplate="{DataTemplate views:DashboardPage}"
                Route="DashboardPage" />
        </Tab>
        <Tab Title="My Profile" Icon="dotnet_bot.png">
            <ShellContent
                ContentTemplate="{DataTemplate views:ProfilePage}"
                Route="ProfilePage" />
        </Tab>
    </TabBar>

</Shell>

